@using RSS_Reader.Models.DataModels
@using RSS_Reader.Models.ViewModels
@model FeedViewModel

@if (Model.FeedError != null)
{
    <div class="alert alert-warning alert-dismissible fade show mb-2" role="alert">
        <strong>Error:</strong> @Model.FeedError
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.TotalCount == 0)
{
    <div class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
        <p class="text-muted">
            @if (!string.IsNullOrEmpty(Model.Query))
            {
                <span>No entries match your search.</span>
            }
            else if (Model.FilterBy == "unread")
            {
                <span>No unread entries.</span>
            }
            else
            {
                <span>No entries available.</span>
            }
        </p>
    </div>
}
else
{
    @foreach (var item in Model.Entries)
    {
        <div class="card mt-2 @(item.IsRead ? "card-read" : "card-unread")" style="width: 100%;">
            <div class="card-body d-lg-inline-flex justify-content-between">
                <div class="col-lg-10">
                    <div class="row" style="width: 100%;">
                        <h5 class="card-title @(item.IsRead ? "" : "fw-bold")">@item.Title</h5>
                        <p class="card-text"><small class="text-muted">Last updated @item.PubDate</small></p>
                    </div>
                    <div class="row">
                        <p class="card-text">@item.Description</p>
                    </div>
                </div>
                <div class="col-lg-2 d-flex flex-column gap-1">

                    @* --- Toggle read/unread button --- *@
                    <button class="btn btn-sm btn-outline-secondary read-toggle w-100" data-entry-id="@item.Id"
                            data-is-read="@item.IsRead.ToString().ToLower()"
                            title="@(item.IsRead ? "Mark unread" : "Mark read")">
                        @(item.IsRead ? "◉" : "○")
                    </button>

                    @if (item.FullContent == null || item.FullContent.Length < 500)
                    {
                        <button data-entry-id="@item.Id" data-external-url="@item.Link"
                                class="btn btn-primary external-read h-100 w-100 d-flex justify-content-center align-items-center">
                            Read More<br>(External)
                        </button>
                    }
                    else
                    {
                        <button data-url="/article/@item.Id"
                                class="btn btn-success article-link h-100 w-100 d-flex justify-content-center align-items-center">Read
                            More</button>
                    }
                </div>
            </div>
        </div>
    }

    @* Pagination *@
    if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination pagination-sm justify-content-center mb-1">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage - 1)">Previous</a>
                </li>
                <li class="page-item active">
                    <span class="page-link">Page @Model.CurrentPage of @Model.TotalPages</span>
                </li>
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="#" data-page="@(Model.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
    <p class="text-muted text-center small">
        Showing @Model.ShowingFrom–@Model.ShowingTo of @Model.TotalCount results
    </p>
}
