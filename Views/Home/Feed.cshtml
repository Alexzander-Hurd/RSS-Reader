@using RSS_Reader.Models.DataModels
@model Feed
@{
    ViewBag.Title = "Feed";
}

<div class="d-md-flex flex-col align-items-center justify-content-around">
    <div class="d-flex flex-column col-md-6 align-items-center justify-content-center">
        <div class="row" style="width: 100%;">
            <h2 class="text-center">@Model.Title</h2>
        </div>
        <div class="row" style="width: 100%;">
            <p class="text-center">@Model.Description</p>
        </div>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-primary refresh-button align-self-center justify-self-center" data-url="/feed/@Model.Id">
            Refresh Feed
        </button>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-outline-primary mark-all-read align-self-center justify-self-center"
                data-feed-id="@Model.Id">
            Mark All Read
        </button>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-danger delete align-self-center justify-self-center" data-url="/deletefeed/@Model.Id"
                data-bs-toggle="modal" data-bs-target="#deleteModal">
            Delete Feed
        </button>
    </div>
</div>

<div class="h-100 d-flex flex-column">
    <div class="flex-grow-1 overflow-auto">
        @foreach (var item in Model.Entries ?? new List<Entry>())
        {
            <div class="card mt-2 @(item.IsRead ? "card-read" : "card-unread")" style="width: 100%;">
                <div class="card-body d-lg-inline-flex justify-content-between">
                    <div class="col-lg-10">
                        <div class="row" style="width: 100%;">
                            <h5 class="card-title @(item.IsRead ? "" : "fw-bold")">@item.Title</h5>
                            <p class="card-text"><small class="text-muted">Last updated @item.PubDate</small></p>
                        </div>
                        <div class="row">
                            <p class="card-text">@item.Description</p>
                        </div>
                    </div>
                    <div class="col-lg-2 d-flex flex-column gap-1">

                        @* --- Toggle read/unread button --- *@
                        <button class="btn btn-sm btn-outline-secondary read-toggle w-100" data-entry-id="@item.Id"
                                data-is-read="@item.IsRead.ToString().ToLower()"
                                title="@(item.IsRead ? "Mark unread" : "Mark read")">
                            @(item.IsRead ? "◉" : "○")
                        </button>

                        @if (item.FullContent == null || item.FullContent.Length < 500)
                        {
                            <button data-entry-id="@item.Id" data-external-url="@item.Link"
                                    class="btn btn-primary external-read h-100 w-100 d-flex justify-content-center align-items-center">
                                Read More<br>(External)
                            </button>
                        }
                        else
                        {
                            <button data-url="/article/@item.Id"
                                    class="btn btn-success article-link h-100 w-100 d-flex justify-content-center align-items-center">Read
                                More</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
