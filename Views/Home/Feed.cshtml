@using RSS_Reader.Models.DataModels
@using RSS_Reader.Models.ViewModels
@model FeedViewModel
@{
    ViewBag.Title = "Feed";
    var isNewest = Model.SortBy == "newest";
    var isOldest = Model.SortBy == "oldest";
    var isAll = Model.FilterBy == "all";
    var isUnread = Model.FilterBy == "unread";
    var pp10 = Model.PerPage == 10;
    var pp20 = Model.PerPage == 20;
    var pp50 = Model.PerPage == 50;
}

<div class="d-md-flex flex-col align-items-center justify-content-around">
    <div class="d-flex flex-column col-md-6 align-items-center justify-content-center">
        <div class="row" style="width: 100%;">
            <h2 class="text-center">
                @Model.Feed.Title
                @if (!string.IsNullOrEmpty(Model.Feed.FeedType))
                {
                    <span class="badge bg-secondary ms-2 align-middle" style="font-size: 0.6em;">@Model.Feed.FeedType</span>
                }
            </h2>
        </div>
        <div class="row" style="width: 100%;">
            <p class="text-center">@Model.Feed.Description</p>
        </div>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-primary refresh-button align-self-center justify-self-center" data-url="/feed/@Model.Feed.Id">
            Refresh Feed
        </button>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-outline-primary mark-all-read align-self-center justify-self-center"
                data-feed-id="@Model.Feed.Id">
            Mark All Read
        </button>
    </div>
    <div class="d-flex col-md-2 align-items-center justify-content-center">
        <button class="btn btn-danger delete align-self-center justify-self-center" data-url="/deletefeed/@Model.Feed.Id"
                data-bs-toggle="modal" data-bs-target="#deleteModal">
            Delete Feed
        </button>
    </div>
</div>

@if (Model.FeedError != null)
{
    <div class="alert alert-warning alert-dismissible fade show mt-3" role="alert">
        <strong>Error loading feed:</strong> @Model.FeedError
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* Search / Filter / Sort / Per-Page Controls *@
<div class="row g-2 mb-3 mt-2 align-items-end">
    <div class="col-md-4">
        <input type="search" id="feed-search" class="form-control" placeholder="Search entries..."
               value="@Model.Query">
    </div>
    <div class="col-md-3">
        <select id="feed-sort" class="form-select">
            <option value="newest" selected="@isNewest">Newest First</option>
            <option value="oldest" selected="@isOldest">Oldest First</option>
        </select>
    </div>
    <div class="col-md-3">
        <select id="feed-filter" class="form-select">
            <option value="all" selected="@isAll">All Entries</option>
            <option value="unread" selected="@isUnread">Unread Only</option>
        </select>
    </div>
    <div class="col-md-2">
        <select id="feed-perpage" class="form-select">
            <option value="10" selected="@pp10">10 / page</option>
            <option value="20" selected="@pp20">20 / page</option>
            <option value="50" selected="@pp50">50 / page</option>
        </select>
    </div>
</div>

@* Entries (replaced by AJAX on filter/search/page change) *@
<div class="h-100 d-flex flex-column">
    <div id="feed-entries-container" class="flex-grow-1 overflow-auto">
        @await Html.PartialAsync("_FeedEntries", Model)
    </div>
</div>
